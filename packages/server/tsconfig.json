{
  "compilerOptions": {
    "target": "esnext",
    "module": "commonjs",
    "moduleResolution": "node",
    "rootDir": "./src",
    "outDir": "./dist",
    "lib": ["ESNext", "DOM"],
    "sourceMap": true,
    "removeComments": true,
    "experimentalDecorators": true,
    "isolatedModules": true,
    "emitDecoratorMetadata": true,
    "allowJs": true,
    "noEmit": true,
    "strict": true,
    "esModuleInterop": true,
    "types": [
      "node"
    ],
    "typeRoots": [
      "node_modules/@types"
    ]
   },
  "include": [
    "./src/**/*"
  ],
  "exclude": [
    "./src/public/",
    "src/types/*.ts", 
    "node_modules", 
    ".vscode"
  ],
  "scripts": {
    "check-types": "tsc"
  }
}
