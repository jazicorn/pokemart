{
  "compilerOptions": {

    "target": "esnext",
    "module": "commonjs",
    "lib": ["ESNext", "DOM"],

    "moduleResolution": "node",
    "esModuleInterop": true,

    "baseUrl": "./",
    "paths": {
      "@pokemart/*": ["packages/*"]
    },
    "strict": true,

    "jsx": "react-jsx",
    "experimentalDecorators": true,
    "resolveJsonModule": true,
    "skipLibCheck": true
    },
    "references": [
      {
        "path": "packages/client"
      },
      {
        "path": "packages/server"
      },
      {
        "path": "packages/test"
      }
    ],
    "include": [".eslintrc.json", "./src/**/*", "./__helpers__/*", "packages/server/src/**/*" ],
    "exclude": ["node_modules", "**/node_modules/*", "dist", "*.d.ts"]

}
